{
  "name": "@caliber/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/server.ts",
  "types": "./src/server.ts",
  "exports": {
    ".": {
      "types": "./src/server.ts",
      "default": "./src/server.ts"
    },
    "./trpc": {
      "types": "./src/trpc/index.ts",
      "default": "./src/trpc/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@caliber/auth": "workspace:*",
    "@caliber/config": "workspace:*",
    "@caliber/db": "workspace:*",
    "@caliber/evaluator": "workspace:*",
    "@caliber/gateway-core": "workspace:*",
    "@fastify/cookie": "^11.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@trpc/server": "^11.0.0",
    "bullmq": "^5.34.0",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.10.1",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "@trpc/client": "^11.0.0",
    "@types/ioredis-mock": "^8.2.7",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "ioredis-mock": "^8.13.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
