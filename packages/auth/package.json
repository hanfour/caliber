{
  "name": "@caliber/auth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./rbac": {
      "types": "./dist/rbac/index.d.ts",
      "import": "./dist/rbac/index.js",
      "default": "./dist/rbac/index.js"
    },
    "./rbac/check": {
      "types": "./dist/rbac/check.d.ts",
      "import": "./dist/rbac/check.js",
      "default": "./dist/rbac/check.js"
    },
    "./rbac/actions": {
      "types": "./dist/rbac/actions.d.ts",
      "import": "./dist/rbac/actions.js",
      "default": "./dist/rbac/actions.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@caliber/config": "workspace:*",
    "@caliber/db": "workspace:*",
    "@auth/core": "^0.34.3",
    "@auth/drizzle-adapter": "^1.7.0",
    "drizzle-orm": "^0.45.2",
    "next-auth": "5.0.0-beta.31"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^4.1.4",
    "pg": "^8.13.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
