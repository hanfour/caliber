# syntax=docker/dockerfile:1.7

###############################################################################
# Base
###############################################################################
FROM node:20-alpine AS base
RUN apk add --no-cache libc6-compat wget \
  && corepack enable
ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH
ENV NEXT_TELEMETRY_DISABLED=1
WORKDIR /repo

###############################################################################
# Stage 1 — deps
###############################################################################
FROM base AS deps
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json turbo.json tsconfig.base.json tsconfig.json ./
COPY apps/api/package.json apps/api/package.json
COPY apps/web/package.json apps/web/package.json
COPY packages/api-types/package.json packages/api-types/package.json
COPY packages/auth/package.json packages/auth/package.json
COPY packages/config/package.json packages/config/package.json
COPY packages/core/package.json packages/core/package.json
COPY packages/db/package.json packages/db/package.json
COPY packages/evaluator/package.json packages/evaluator/package.json
COPY packages/gateway-core/package.json packages/gateway-core/package.json
RUN --mount=type=cache,id=pnpm-store,target=/pnpm/store \
  pnpm install --frozen-lockfile

###############################################################################
# Stage 2 — build Next.js in standalone mode
###############################################################################
FROM deps AS build
# web needs api's type entry (via @caliber/api-types → @caliber/api/trpc); include
# api sources so tsc/Next.js can resolve the type graph.
COPY apps/api apps/api
COPY apps/web apps/web
COPY packages/api-types packages/api-types
COPY packages/auth packages/auth
COPY packages/config packages/config
COPY packages/core packages/core
COPY packages/db packages/db
COPY packages/evaluator packages/evaluator
# gateway-core: web's turbo graph pulls in @caliber/api (via @caliber/api-types),
# and @caliber/api now imports encryptCredential from @caliber/gateway-core. The
# source needs to be present for the turbo build to succeed even though
# nothing in the Next.js runtime bundle ends up using it.
COPY packages/gateway-core packages/gateway-core
RUN pnpm turbo run build --filter=@caliber/web...

###############################################################################
# Stage 3 — runtime: copy only the standalone bundle + static + public
###############################################################################
FROM node:20-alpine AS runtime
RUN apk add --no-cache wget
ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=3000 \
    HOSTNAME=0.0.0.0
WORKDIR /app
RUN addgroup -g 1001 -S aide && adduser -u 1001 -S aide -G aide

# The standalone output is rooted at the repo root (outputFileTracingRoot),
# so .next/standalone/ contains: apps/web/server.js + packages/ + node_modules.
# Copy that whole tree to /app, then layer .next/static and public on top.
COPY --from=build --chown=aide:aide /repo/apps/web/.next/standalone /app
COPY --from=build --chown=aide:aide /repo/apps/web/.next/static /app/apps/web/.next/static
COPY --from=build --chown=aide:aide /repo/apps/web/public /app/apps/web/public
# scripts/ holds the API_INTERNAL_URL substitution helper; not included in the
# Next.js standalone bundle by default, so copy explicitly.
COPY --from=build --chown=aide:aide /repo/apps/web/scripts /app/apps/web/scripts

# Runtime entrypoint substitutes the API_INTERNAL_URL placeholder into the
# baked routes-manifest.json before booting node. See the script + comment in
# apps/web/next.config.mjs for the full rationale.
COPY --chown=aide:aide docker/web-entrypoint.sh /app/web-entrypoint.sh
RUN chmod +x /app/web-entrypoint.sh

USER aide
EXPOSE 3000
# Probe /sign-in because "/" returns a 307 redirect and busybox wget doesn't
# follow redirects by default. /sign-in is a static 200 regardless of env.
HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
  CMD wget -qO- http://localhost:3000/sign-in >/dev/null 2>&1 || exit 1
ENTRYPOINT ["/app/web-entrypoint.sh"]
